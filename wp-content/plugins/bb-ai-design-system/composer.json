{
	"name": "fastline/fl-design-system",
	"description": "AI-powered block, layout, and design system creation for WordPress.",
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"wp-coding-standards/wpcs": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"FL\\DesignSystem\\": "packages/ai-design-system/backend/",
			"FL\\DesignSystem\\Updater\\": "packages/updater/backend/",
			"FL\\DesignSystem\\McpOAuth\\": "packages/mcp-oauth/backend/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"FL\\DesignSystem\\Tests\\": "packages/ai-design-system/tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"require": {
		"enshrined/svg-sanitize": "^0.22"
	}
}
