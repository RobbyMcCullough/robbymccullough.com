	{
		"name": "testimonial section: repeater of rating + name + quote + avatar items",
		"annotated_html": "<section class=\"testimonials\" data-repeater=\"testimonials\"><article data-repeater-item><div data-field=\"rating\" data-field-max=\"5\" data-field-type=\"rating\"><span class=\"filled\">★</span><span class=\"filled\">★</span><span class=\"filled\">★</span><span class=\"filled\">★</span><span class=\"empty\">☆</span></div><h3 data-field=\"name\">Alice</h3><p data-field=\"quote\">Great product!</p><img alt=\"Alice\" data-field=\"avatar\" src=\"https://example.com/alice.jpg\" /></article><article data-repeater-item><div data-field=\"rating\" data-field-max=\"5\" data-field-type=\"rating\"><span class=\"filled\">★</span><span class=\"filled\">★</span><span class=\"filled\">★</span><span class=\"empty\">☆</span><span class=\"empty\">☆</span></div><h3 data-field=\"name\">Bob</h3><p data-field=\"quote\">Solid choice.</p><img alt=\"Bob\" data-field=\"avatar\" src=\"https://example.com/bob.jpg\" /></article></section>",
		"template": "<section class=\"testimonials\">{{#settings.testimonials}}<article><div>\n  {{#rating}}\n    {{#active}}\n    <span class=\"filled\">★</span>\n    {{/active}}\n    {{^active}}\n    <span class=\"empty\">☆</span>\n    {{/active}}\n  {{/rating}}\n</div><h3>{{{name}}}</h3><p>{{{quote}}}</p><img src=\"{{avatar}}\" alt=\"{{avatar.alt}}\" /></article>{{/settings.testimonials}}</section>",
		"settings": {
			"testimonials": [
				{
					"rating": { "value": 4, "max": 5 },
					"name": "Alice",
					"quote": "Great product!",
					"avatar": { "url": "https://example.com/alice.jpg", "alt": "Alice", "id": null, "size": null }
				},
				{
					"rating": { "value": 3, "max": 5 },
					"name": "Bob",
					"quote": "Solid choice.",
					"avatar": { "url": "https://example.com/bob.jpg", "alt": "Bob", "id": null, "size": null }
				}
			]
		}
	},
	{
