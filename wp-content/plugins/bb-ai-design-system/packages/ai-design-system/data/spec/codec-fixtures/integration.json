[
	{
		"name": "hero block: heading + editor paragraph + image + CTA link at top level",
		"annotated_html": "<section class=\"hero\"><h1 data-field=\"headline\">Welcome to our site</h1><p data-field=\"subhead\" data-field-type=\"editor\">Build <strong>amazing</strong> things faster.</p><img alt=\"Hero\" data-field=\"hero_image\" src=\"https://example.com/hero.jpg\" /><a data-field=\"cta\" href=\"https://example.com/start\">Get Started</a></section>",
		"template": "<section class=\"hero\"><h1>{{{settings.headline}}}</h1><p>{{{settings.subhead}}}</p><img src=\"{{settings.hero_image}}\" alt=\"{{settings.hero_image.alt}}\" /><a href=\"{{settings.cta.href}}\" target=\"{{settings.cta.target}}\" rel=\"{{settings.cta.rel}}\">{{{settings.cta.text}}}</a></section>",
		"settings": {
			"headline": "Welcome to our site",
			"subhead": "Build <strong>amazing</strong> things faster.",
			"hero_image": { "url": "https://example.com/hero.jpg", "alt": "Hero", "id": null, "size": null },
			"cta": { "text": "Get Started", "href": "https://example.com/start", "target": "", "rel": "" }
		}
	},
	{
		"name": "feature grid: repeater of icon + title + body + bare link items",
		"annotated_html": "<section class=\"features\" data-repeater=\"features\"><article data-repeater-item><svg data-field=\"icon\" height=\"32\" width=\"32\"><title>icon</title></svg><h3 data-field=\"title\">Fast</h3><p data-field=\"body\">Lightning quick.</p><a data-field=\"link\" href=\"https://a.com\">Learn more</a></article><article data-repeater-item><svg data-field=\"icon\" height=\"32\" width=\"32\"><title>icon</title></svg><h3 data-field=\"title\">Reliable</h3><p data-field=\"body\">Always available.</p><a data-field=\"link\" href=\"https://b.com\">Learn more</a></article></section>",
		"template": "<section class=\"features\">{{#settings.features}}<article>{{{icon}}}<h3>{{{title}}}</h3><p>{{{body}}}</p><a href=\"{{link.href}}\" target=\"{{link.target}}\" rel=\"{{link.rel}}\">{{{link.text}}}</a></article>{{/settings.features}}</section>",
		"settings": {
			"features": [
				{
					"icon": "<svg data-field=\"icon\" height=\"32\" width=\"32\"><title>icon</title></svg>",
					"title": "Fast",
					"body": "Lightning quick.",
					"link": { "text": "Learn more", "href": "https://a.com", "target": "", "rel": "" }
				},
				{
					"icon": "<svg data-field=\"icon\" height=\"32\" width=\"32\"><title>icon</title></svg>",
					"title": "Reliable",
					"body": "Always available.",
					"link": { "text": "Learn more", "href": "https://b.com", "target": "", "rel": "" }
				}
			]
		}
