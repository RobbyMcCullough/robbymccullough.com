	{
		"name": "nested repeater: link inside an inner repeater",
		"annotated_html": "<section data-repeater=\"groups\"><div data-repeater-item><h3 data-field=\"title\">Group A</h3><ul data-repeater=\"links\"><li data-repeater-item><a data-field=\"link\" href=\"https://a.com\">Alpha</a></li></ul></div></section>",
		"template": "<section>{{#settings.groups}}<div><h3>{{{title}}}</h3><ul>{{#links}}<li><a href=\"{{link.href}}\" target=\"{{link.target}}\" rel=\"{{link.rel}}\">{{{link.text}}}</a></li>{{/links}}</ul></div>{{/settings.groups}}</section>",
		"settings": {
			"groups": [
				{
					"title": "Group A",
					"links": [
						{ "link": { "text": "Alpha", "href": "https://a.com", "target": "", "rel": "" } }
					]
				}
			]
		}
	},
	{
		"name": "icon-only link: top-level <a data-field-href> wrapping <svg data-field>",
