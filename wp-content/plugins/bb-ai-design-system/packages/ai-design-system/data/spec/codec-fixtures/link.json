		"settings": {
			"cta_url": "https://example.com/",
			"cta_icon": "<svg data-field=\"cta_icon\" viewBox=\"0 0 24 24\"><path d=\"M5 12h14M13 5l7 7-7 7\" /></svg>"
		}
	},
	{
		"name": "icon-only link in repeater: per-item hrefs survive (regression lock)",
