		"template": "<div>{{#settings.social_links}}<a href=\"{{social_url}}\">{{{social_icon}}}</a>{{/settings.social_links}}</div>",
		"settings": {
			"social_links": [
				{
					"social_url": "https://twitter.com/example",
					"social_icon": "<svg data-field=\"social_icon\" viewBox=\"0 0 24 24\"><path d=\"M22 4l-9 9-5-5\" /></svg>"
				},
				{
					"social_url": "https://github.com/example",
					"social_icon": "<svg data-field=\"social_icon\" viewBox=\"0 0 24 24\"><path d=\"M12 2a10 10 0 0 0-3 19\" /></svg>"
				},
				{
					"social_url": "https://example.com/rss",
					"social_icon": "<svg data-field=\"social_icon\" viewBox=\"0 0 24 24\"><path d=\"M4 11a9 9 0 0 1 9 9\" /></svg>"
				}
			]
		}
