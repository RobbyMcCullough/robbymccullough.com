	{
		"name": "repeater-item: single bare-token link",
		"annotated_html": "<div data-repeater=\"links\"><a data-repeater-item data-field=\"link\" href=\"https://a.com\">Alpha</a></div>",
		"template": "<div>{{#settings.links}}<a href=\"{{link.href}}\" target=\"{{link.target}}\" rel=\"{{link.rel}}\">{{{link.text}}}</a>{{/settings.links}}</div>",
		"settings": {
			"links": [
				{ "link": { "text": "Alpha", "href": "https://a.com", "target": "", "rel": "" } }
			]
		}
	},
	{
		"name": "repeater: two link items vary across items",
		"annotated_html": "<div data-repeater=\"links\"><a data-repeater-item data-field=\"link\" href=\"https://a.com\">Alpha</a><a data-repeater-item data-field=\"link\" href=\"https://b.com\" target=\"_blank\" rel=\"noopener\">Beta</a></div>",
		"template": "<div>{{#settings.links}}<a href=\"{{link.href}}\" target=\"{{link.target}}\" rel=\"{{link.rel}}\">{{{link.text}}}</a>{{/settings.links}}</div>",
		"settings": {
			"links": [
				{ "link": { "text": "Alpha", "href": "https://a.com", "target": "", "rel": "" } },
				{ "link": { "text": "Beta", "href": "https://b.com", "target": "_blank", "rel": "noopener" } }
			]
		}
	},
	{
		"name": "clean output: no leftover mustache",
