	{
		"name": "link compound + leading svg icon: extracted into sibling field",
		"annotated_html": "<a data-field=\"contact\" href=\"mailto:hello@example.com\"><svg viewBox=\"0 0 24 24\"><path d=\"M0 0\" /></svg>hello</a>",
		"template": "<a href=\"{{settings.contact.href}}\" target=\"{{settings.contact.target}}\" rel=\"{{settings.contact.rel}}\">{{{settings.contact_icon}}}{{{settings.contact.text}}}</a>",
		"settings": {
			"contact": { "text": "hello", "href": "mailto:hello@example.com", "target": "", "rel": "" },
			"contact_icon": "<svg viewBox=\"0 0 24 24\" data-field=\"contact_icon\"><path d=\"M0 0\" /></svg>"
		},
		"reconstructed_html": "<a data-field=\"contact\" href=\"mailto:hello@example.com\"><svg viewBox=\"0 0 24 24\" data-field=\"contact_icon\"><path d=\"M0 0\" /></svg>hello</a>"
	},
