[
	{
		"name": "top-level: text and href only",
		"annotated_html": "<a data-field=\"cta\" href=\"https://example.com\">Click Here</a>",
		"template": "<a href=\"{{settings.cta.href}}\" target=\"{{settings.cta.target}}\" rel=\"{{settings.cta.rel}}\">{{{settings.cta.text}}}</a>",
		"settings": {
			"cta": { "text": "Click Here", "href": "https://example.com", "target": "", "rel": "" }
		}
	},
